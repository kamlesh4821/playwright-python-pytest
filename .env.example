# Environment selection: local | ci | staging | qa
ENV=local

# Browser: chromium | firefox | webkit
BROWSER=chromium

# Headless mode: true | false
HEADLESS=false

# Application
BASE_URL=https://www.saucedemo.com

# Test credentials (never hardcode real values)
TEST_USERNAME=standard_user
TEST_PASSWORD=secret_sauce

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=testdb
DB_USER=testuser
DB_PASSWORD=testpass

# Reporting
ALLURE_RESULTS_DIR=allure-results

# CI options
RETRY_COUNT=1
PARALLEL_WORKERS=4
VIDEO=false

# Notifications
TEAMS_WEBHOOK_URL=
